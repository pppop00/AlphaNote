# Personal Stock RAG - Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values

# OpenAI API Key (optional - only needed if using OpenAI instead of local LLM)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Hugging Face token (optional - only needed for private models/datasets)
HF_TOKEN=hf_your_token_here

# Note: By default, this app uses local LLM via Ollama (free!)
# To use OpenAI instead, set USE_LOCAL_LLM=False in app.py
